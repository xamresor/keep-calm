APP_NAME="Keep Calm API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

# Database (use sqlite for local dev)
DB_CONNECTION=sqlite
DB_DATABASE=

# Or MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=keepkalm
# DB_USERNAME=root
# DB_PASSWORD=

# Gemini API (leave empty to use file provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_BASE_URI=https://generativelanguage.googleapis.com/v1beta/
# Optional (Windows TLS fix): absolute path to CA bundle, e.g. C:\certs\cacert.pem
GEMINI_CA_BUNDLE=

# Optional: path to JSON file when GEMINI_API_KEY is empty
# DASHBOARD_FILE=/path/to/sample_dashboard.json

# Cache (file driver, or redis if configured)
CACHE_DRIVER=file
